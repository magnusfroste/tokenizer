ROUTER_ADDR=:8080
MOCK_PROVIDER_ADDR=:18080
MOCK_PROVIDER_URL=http://localhost:18080
LOCAL_API_KEY=local_router_key
DATABASE_URL=postgres://tokenizer:tokenizer@localhost:5432/tokenizer?sslmode=disable
LOG_LEVEL=info
# Retention/privacy (ISSUE-045)
ROUTER_RETENTION_DAYS=30
ROUTER_RETENTION_INTERVAL_HOURS=24
# Prompt logging is OFF by default; only enable for debugging.
ROUTER_PROMPT_LOGGING=false
# Budget caps (ISSUE-051). 0 disables; sets a per-tenant cap (USD) for tn_local.
ROUTER_BUDGET_USD=0
