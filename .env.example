ROUTER_ADDR=:8080
MOCK_PROVIDER_ADDR=:18080
MOCK_PROVIDER_URL=http://localhost:18080
LOCAL_API_KEY=local_router_key
# OpenRouter (real OpenAI-compatible provider). When set, the router uses the
# OpenRouter registry instead of the mock provider. Leave empty to use the mock.
OPENROUTER_API_KEY=
# Optional OpenRouter attribution headers (HTTP-Referer / X-Title) for app ranking.
OPENROUTER_REFERER=
OPENROUTER_TITLE=
# Model roster: which OpenRouter model fills each routing tier. Use OpenRouter
# slugs (e.g. z-ai/glm-4.6, openai/gpt-4o-mini). Empty keeps the built-in
# default. Routing (task -> tier) is unchanged; this only swaps the model.
ROUTER_MODEL_CHEAP=
ROUTER_MODEL_BALANCED=
ROUTER_MODEL_PREMIUM=
DATABASE_URL=postgres://tokenizer:tokenizer@localhost:5432/tokenizer?sslmode=disable
LOG_LEVEL=info
# Dashboard: set a password to open /router/dashboard directly in a browser
# (HTTP Basic Auth). Empty keeps the Bearer + admin gate (not browser-friendly).
ROUTER_DASHBOARD_PASSWORD=
# Persistence: directory on a (mounted) volume where spend/savings are persisted
# so the dashboard survives restarts/redeploys. Empty = in-memory only.
ROUTER_DATA_DIR=
# Retention/privacy (ISSUE-045)
ROUTER_RETENTION_DAYS=30
ROUTER_RETENTION_INTERVAL_HOURS=24
# Prompt logging is OFF by default; only enable for debugging.
ROUTER_PROMPT_LOGGING=false
# Budget caps (ISSUE-051). 0 disables; sets a per-tenant cap (USD) for tn_local.
ROUTER_BUDGET_USD=0
# Route decision cache (ISSUE-052). 0 disables; TTL for cached low-risk decisions.
ROUTER_DECISION_CACHE_TTL_SECONDS=60
# Global conservative mode (ISSUE-060). Incident lever: route uncertain
# classifications at >= balanced. See 07-operations/runbook.md.
ROUTER_CONSERVATIVE_MODE=false
# Runtime policy file paths. Empty uses the built-in default policy; shadow is
# disabled unless ROUTER_SHADOW_POLICY_PATH is set.
ROUTER_POLICY_PATH=
ROUTER_SHADOW_POLICY_PATH=
# Context processors are still policy-gated; this is only an operator rollout /
# kill switch. Prompt adapters are disabled unless explicitly enabled.
ROUTER_CONTEXT_PIPELINE_ENABLED=false
ROUTER_PROMPT_ADAPTER_ENABLED=false
