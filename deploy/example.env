# tokenizer router — example environment for EasyPanel / docker compose.
# Copy the lines you need into the service's env field in EasyPanel.
# Only LOCAL_API_KEY is required; everything else has a safe default.

# --- Auth (REQUIRED) ---------------------------------------------------------
# Clients send this as `Authorization: Bearer <key>`. Use a strong secret:
#   openssl rand -hex 24
LOCAL_API_KEY=

# --- Provider ----------------------------------------------------------------
# Set OPENROUTER_API_KEY to route through OpenRouter (a real OpenAI-compatible
# aggregator). Leave blank to fall back to the in-process mock provider.
OPENROUTER_API_KEY=
# Optional OpenRouter attribution (app ranking):
OPENROUTER_REFERER=
OPENROUTER_TITLE=

# --- Cost guard --------------------------------------------------------------
# Per-tenant spend cap in USD; 0 disables. When exceeded the router downgrades.
ROUTER_BUDGET_USD=0

# --- Privacy / retention -----------------------------------------------------
ROUTER_PROMPT_LOGGING=false
ROUTER_RETENTION_DAYS=30

# --- Incident lever ----------------------------------------------------------
# Route uncertain classifications at >= balanced (see 07-operations/runbook.md).
ROUTER_CONSERVATIVE_MODE=false

# --- Persistence -------------------------------------------------------------
# Directory on a mounted volume where spend/savings are persisted so the
# dashboard survives restarts/redeploys. The compose file mounts ./data here.
ROUTER_DATA_DIR=/data

# --- Dashboard ---------------------------------------------------------------
# Set a password to open /router/dashboard directly in a browser (Basic Auth):
# the browser shows a login prompt. Leave blank to keep the Bearer + admin gate.
ROUTER_DASHBOARD_PASSWORD=

# --- Networking / logging (usually leave as default) -------------------------
APP_BIND=0.0.0.0
APP_PORT=8080
LOG_LEVEL=info
